      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.50, rate(order_publish_duration_seconds_bucket{application=\"ecommerce\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.95, rate(order_publish_duration_seconds_bucket{application=\"ecommerce\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.99, rate(order_publish_duration_seconds_bucket{application=\"ecommerce\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    },

